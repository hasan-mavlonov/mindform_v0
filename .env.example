# ------------------------------------------------------------------------------
# MindForm environment configuration
#
#   cp .env.example .env      then fill in ONE key below.
#
# .env is git-ignored, so your secrets never get committed. config.py reads this
# file at startup; real shell environment variables take precedence over it.
#
# Everything LLM-related is optional: with no key, MindForm runs on its
# deterministic heuristics (personality still forms, genesis still seeds).
# ------------------------------------------------------------------------------

# --- DEFAULT: Google Gemini 3.5 Flash (fast + smart, GA) -----------------------
# Served through the Gemini API's OpenAI-compatible endpoint, so the OpenAI SDK
# talks to it unchanged. Get a key at Google AI Studio:
#   https://aistudio.google.com/apikey
# This is all you need -- gemini-3.5-flash is the baked-in default model.
GEMINI_API_KEY=

# Want it even faster? The current speed king (lighter, still capable):
# LLM_MODEL=gemini-3.1-flash-lite

# --- ALTERNATIVE: OpenAI (GPT-5.x small tiers) ---------------------------------
# Uncomment all three lines and put your OpenAI key in LLM_API_KEY.
# gpt-5.4-mini is the fast/cheap sweet spot; gpt-5.6-luna is the newest fast tier;
# gpt-5.4-nano is the absolute cheapest.
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-5.4-mini

# --- Any other OpenAI-compatible provider works the same way -------------------
# LLM_API_KEY=...
# LLM_BASE_URL=https://your-provider/v1
# LLM_MODEL=model-id
#
# Previous setups keep working unchanged if you already have them:
#   Gemma 4 via Gemini:  GEMINI_API_KEY=...  +  LLM_MODEL=gemma-4-31b-it
#   DeepSeek (legacy names honored):
#     DEEPSEEK_API_KEY=sk-...
#     DEEPSEEK_BASE_URL=https://api.deepseek.com
#     DEEPSEEK_MODEL=deepseek-chat

# --- Tuning (optional) ----------------------------------------------------------
# LLM_FORMATION_RATE=0.3              # how far one experience nudges a trait
