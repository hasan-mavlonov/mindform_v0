# ------------------------------------------------------------------------------
# MindForm environment configuration
#
#   cp .env.example .env      then fill in your key below.
#
# .env is git-ignored, so your secrets never get committed. config.py reads this
# file at startup; real shell environment variables take precedence over it.
#
# Everything LLM-related is optional: with no key, MindForm runs on its
# deterministic heuristics (personality still forms, genesis still seeds).
# ------------------------------------------------------------------------------

# --- Google Gemma 4 (default LLM for the formation push, genesis, and replies) -
# Gemma 4 is served through the Gemini API's OpenAI-compatible endpoint, so the
# OpenAI SDK talks to it unchanged. Get a free key at Google AI Studio:
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional overrides (sensible Gemma 4 defaults are baked into config.py):
# LLM_MODEL=gemma-4-12b-it            # also: gemma-4-26b-a4b-it, gemma-4-31b-it
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_FORMATION_RATE=0.3              # how far one experience nudges a trait

# --- Use any other OpenAI-compatible provider instead (optional) --------------
# Point these three at any compatible endpoint and put its key in LLM_API_KEY.
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
#
# DeepSeek (the previous default) still works via the same path -- the legacy
# DEEPSEEK_* names are honored for backward compatibility:
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
