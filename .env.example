# ------------------------------------------------------------------------------
# MindForm environment configuration
#
#   cp .env.example .env      then fill in your key(s) below.
#
# .env is git-ignored, so your secrets never get committed. config.py reads this
# file at startup; real shell environment variables take precedence over it.
# ------------------------------------------------------------------------------

# --- DeepSeek (LLM personality-formation push) --------------------------------
# OpenAI-compatible, cheap, reachable from mainland China.
# Get a key: https://platform.deepseek.com/  ->  API keys
DEEPSEEK_API_KEY=

# Optional overrides (sensible defaults are baked into config.py):
# DEEPSEEK_MODEL=deepseek-chat              # cheapest chat model; good for scoring
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_FORMATION_RATE=0.3                    # how far one experience nudges a trait

# --- Alternative OpenAI-compatible provider (optional) ------------------------
# The push path uses the OpenAI SDK, so any compatible endpoint works: point
# DEEPSEEK_BASE_URL + DEEPSEEK_MODEL at it and put its key in DEEPSEEK_API_KEY.
# Example (OpenAI itself):
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_MODEL=gpt-4o-mini
